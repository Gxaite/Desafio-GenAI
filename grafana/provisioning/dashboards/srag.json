      "datasource": { "type": "postgres", "uid": "postgres-srag" },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2, "min": 0, "max": 60, "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "#3b82f6", "value": null }, { "color": "orange", "value": 40 }, { "color": "red", "value": 70 } ] } }, "overrides": [] },
      "options": { "showThresholdLabels": false, "showThresholdMarkers": true, "reduceOptions": { "calcs": ["lastNotNull"], "fields": "" } },
      "targets": [ { "refId": "A", "format": "table", "datasource": { "type": "postgres", "uid": "postgres-srag" }, "rawSql": "SELECT round(100.0*sum(uti_sim)/nullif(sum(uti_sim+uti_nao),0),2) AS valor FROM gold.gold_mart_srag_diario WHERE $__timeFilter(dt) AND dt <= (SELECT max(dt) - INTERVAL '${dias_prov} days' FROM gold.gold_mart_srag_diario) AND uf IN (${uf:singlequote})" } ]
    },
