          },
          "rawSql": "WITH indicadores AS (SELECT uf AS \"UF\", sum(casos) AS \"Casos\", round(100.0*sum(ev_obito)/nullif(sum(ev_cura+ev_obito+ev_obito_outras),0),1) AS \"Mortalidade %\", round(100.0*sum(uti_sim)/nullif(sum(uti_sim+uti_nao),0),1) AS \"UTI %\", round(100.0*sum(vac_sim)/nullif(sum(vac_sim+vac_nao),0),1) AS \"Vacinação %\" FROM gold.gold_mart_srag_diario WHERE $__timeFilter(dt) AND dt <= (SELECT max(dt) - INTERVAL '${dias_prov} days' FROM gold.gold_mart_srag_diario) AND uf IN (${uf:singlequote}) GROUP BY uf HAVING sum(casos) > 100) SELECT \"UF\", \"Casos\", \"Mortalidade %\", \"UTI %\", \"Vacinação %\", round((coalesce(\"Mortalidade %\",0) + coalesce(\"UTI %\",0) + (100 - coalesce(\"Vacinação %\",0))) / 3.0, 1) AS \"Score\" FROM indicadores ORDER BY \"Score\" DESC LIMIT 10"
