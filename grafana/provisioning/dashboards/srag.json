  "time": { "from": "now-2y", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "regiao", "type": "query", "label": "Região",
        "datasource": { "type": "postgres", "uid": "postgres-srag" },
        "definition": "SELECT DISTINCT regiao FROM gold.dim_uf ORDER BY 1",
        "query": "SELECT DISTINCT regiao FROM gold.dim_uf ORDER BY 1",
        "includeAll": true, "multi": true, "refresh": 1, "sort": 1,
        "current": { "text": ["All"], "value": ["$__all"] }
      },
      {
        "name": "uf", "type": "query", "label": "UF",
        "datasource": { "type": "postgres", "uid": "postgres-srag" },
        "definition": "SELECT DISTINCT uf FROM gold.dim_uf WHERE regiao IN (${regiao:singlequote}) ORDER BY 1",
        "query": "SELECT DISTINCT uf FROM gold.dim_uf WHERE regiao IN (${regiao:singlequote}) ORDER BY 1",
        "includeAll": true, "multi": true, "refresh": 1, "sort": 1,
        "current": { "text": ["All"], "value": ["$__all"] }
      },
      {
        "name": "dias_prov", "type": "constant", "label": "Dias provisórios",
        "query": "14", "current": { "text": "14", "value": "14" }, "hide": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Casos (período)",
      "gridPos": { "h": 5, "w": 5, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres-srag" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "#3b82f6" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "textMode": "value_and_name", "reduceOptions": { "calcs": ["sum"], "fields": "" } },
      "targets": [ { "refId": "A", "format": "table", "datasource": { "type": "postgres", "uid": "postgres-srag" }, "rawSql": "SELECT dt::timestamp AS time, sum(casos) AS \"Casos\" FROM gold.gold_mart_srag_diario WHERE $__timeFilter(dt) AND dt <= (SELECT max(dt) - INTERVAL '${dias_prov} days' FROM gold.gold_mart_srag_diario) AND uf IN (${uf:singlequote}) GROUP BY dt ORDER BY dt" } ]
    },
    {
      "id": 2, "type": "stat", "title": "Óbitos (período)",
      "gridPos": { "h": 5, "w": 5, "x": 5, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres-srag" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "#ef4444" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "textMode": "value_and_name", "reduceOptions": { "calcs": ["sum"], "fields": "" } },
      "targets": [ { "refId": "A", "format": "table", "datasource": { "type": "postgres", "uid": "postgres-srag" }, "rawSql": "SELECT dt::timestamp AS time, sum(ev_obito) AS \"Óbitos\" FROM gold.gold_mart_srag_diario WHERE $__timeFilter(dt) AND dt <= (SELECT max(dt) - INTERVAL '${dias_prov} days' FROM gold.gold_mart_srag_diario) AND uf IN (${uf:singlequote}) GROUP BY dt ORDER BY dt" } ]
    },
    {
      "id": 3, "type": "gauge", "title": "Mortalidade (%)",
      "gridPos": { "h": 5, "w": 5, "x": 10, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres-srag" },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2, "min": 0, "max": 20, "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 5 }, { "color": "red", "value": 10 } ] } }, "overrides": [] },
      "options": { "showThresholdLabels": false, "showThresholdMarkers": true, "reduceOptions": { "calcs": ["lastNotNull"], "fields": "" } },
      "targets": [ { "refId": "A", "format": "table", "datasource": { "type": "postgres", "uid": "postgres-srag" }, "rawSql": "SELECT round(100.0*sum(ev_obito)/nullif(sum(ev_cura+ev_obito+ev_obito_outras),0),2) AS valor FROM gold.gold_mart_srag_diario WHERE $__timeFilter(dt) AND dt <= (SELECT max(dt) - INTERVAL '${dias_prov} days' FROM gold.gold_mart_srag_diario) AND uf IN (${uf:singlequote})" } ]
    },
    {
      "id": 4, "type": "gauge", "title": "UTI (%, proxy)",
