      "id": 5, "type": "gauge", "title": "Vacinação (%, proxy)",
      "gridPos": { "h": 5, "w": 5, "x": 19, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres-srag" },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2, "min": 0, "max": 100, "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "orange", "value": 40 }, { "color": "green", "value": 70 } ] } }, "overrides": [] },
      "options": { "showThresholdLabels": false, "showThresholdMarkers": true, "reduceOptions": { "calcs": ["lastNotNull"], "fields": "" } },
      "targets": [ { "refId": "A", "format": "table", "datasource": { "type": "postgres", "uid": "postgres-srag" }, "rawSql": "SELECT round(100.0*sum(vac_sim)/nullif(sum(vac_sim+vac_nao),0),2) AS valor FROM gold.gold_mart_srag_diario WHERE $__timeFilter(dt) AND dt <= (SELECT max(dt) - INTERVAL '${dias_prov} days' FROM gold.gold_mart_srag_diario) AND uf IN (${uf:singlequote})" } ]
    },
    {
      "id": 6, "type": "timeseries", "title": "Casos por dia",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "datasource": { "type": "postgres", "uid": "postgres-srag" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 25, "gradientMode": "opacity", "lineWidth": 2, "showPoints": "never" }, "color": { "mode": "fixed", "fixedColor": "#3b82f6" } }, "overrides": [] },
      "options": { "legend": { "showLegend": false }, "tooltip": { "mode": "single" } },
      "targets": [ { "refId": "A", "format": "table", "datasource": { "type": "postgres", "uid": "postgres-srag" }, "rawSql": "SELECT dt::timestamp AS time, sum(casos) AS \"Casos\" FROM gold.gold_mart_srag_diario WHERE $__timeFilter(dt) AND dt <= (SELECT max(dt) - INTERVAL '${dias_prov} days' FROM gold.gold_mart_srag_diario) AND uf IN (${uf:singlequote}) GROUP BY dt ORDER BY dt" } ]
    },
    {
      "id": 7, "type": "timeseries", "title": "Casos por região (semanal)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "postgres", "uid": "postgres-srag" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 18, "gradientMode": "opacity", "lineWidth": 1, "showPoints": "never", "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "showLegend": true, "placement": "bottom", "displayMode": "list" }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "format": "table", "datasource": { "type": "postgres", "uid": "postgres-srag" }, "rawSql": "SELECT date_trunc('week',dt)::timestamp AS time, sum(casos) FILTER (WHERE regiao='Norte') AS \"Norte\", sum(casos) FILTER (WHERE regiao='Nordeste') AS \"Nordeste\", sum(casos) FILTER (WHERE regiao='Centro-Oeste') AS \"Centro-Oeste\", sum(casos) FILTER (WHERE regiao='Sudeste') AS \"Sudeste\", sum(casos) FILTER (WHERE regiao='Sul') AS \"Sul\" FROM gold.gold_mart_srag_diario WHERE $__timeFilter(dt) AND dt <= (SELECT max(dt) - INTERVAL '${dias_prov} days' FROM gold.gold_mart_srag_diario) AND uf IN (${uf:singlequote}) GROUP BY 1 ORDER BY 1" } ]
    },
    {
      "id": 8, "type": "timeseries", "title": "Mortalidade e UTI (%, mensal)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "postgres", "uid": "postgres-srag" },
      "fieldConfig": { "defaults": { "unit": "percent", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 0, "showPoints": "auto" } }, "overrides": [] },
      "options": { "legend": { "showLegend": true, "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "format": "table", "datasource": { "type": "postgres", "uid": "postgres-srag" }, "rawSql": "SELECT date_trunc('month',dt)::timestamp AS time, round(100.0*sum(ev_obito)/nullif(sum(ev_cura+ev_obito+ev_obito_outras),0),2) AS \"Mortalidade %\", round(100.0*sum(uti_sim)/nullif(sum(uti_sim+uti_nao),0),2) AS \"UTI %\" FROM gold.gold_mart_srag_diario WHERE $__timeFilter(dt) AND dt <= (SELECT max(dt) - INTERVAL '${dias_prov} days' FROM gold.gold_mart_srag_diario) AND uf IN (${uf:singlequote}) GROUP BY 1 ORDER BY 1" } ]
    },
    {
      "id": 9, "type": "barchart", "title": "Casos por UF (período)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "postgres", "uid": "postgres-srag" },
      "fieldConfig": { "defaults": { "color": { "mode": "continuous-BlPu" }, "custom": { "fillOpacity": 85, "lineWidth": 0 } }, "overrides": [] },
