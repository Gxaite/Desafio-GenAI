      "targets": [ { "refId": "A", "format": "table", "datasource": { "type": "postgres", "uid": "postgres-srag" }, "rawSql": "SELECT uf, sum(casos) AS casos FROM gold.gold_mart_srag_diario WHERE $__timeFilter(dt) AND dt <= (SELECT max(dt) - INTERVAL '${dias_prov} days' FROM gold.gold_mart_srag_diario) AND uf IN (${uf:singlequote}) GROUP BY uf ORDER BY casos DESC" } ]
    },
    {
      "id": 10, "type": "piechart", "title": "Casos por região (período)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "postgres", "uid": "postgres-srag" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "legend": { "showLegend": true, "placement": "right", "values": ["percent"] }, "pieType": "donut", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "" } },
      "targets": [ { "refId": "A", "format": "table", "datasource": { "type": "postgres", "uid": "postgres-srag" }, "rawSql": "SELECT regiao, sum(casos) AS casos FROM gold.gold_mart_srag_diario WHERE $__timeFilter(dt) AND dt <= (SELECT max(dt) - INTERVAL '${dias_prov} days' FROM gold.gold_mart_srag_diario) AND uf IN (${uf:singlequote}) GROUP BY regiao ORDER BY casos DESC" } ]
    },
    {
      "id": 20, "type": "row", "title": "Observabilidade do agente",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 }, "collapsed": true,
      "panels": [
        {
          "id": 21, "type": "table", "title": "Execuções do agente",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
          "datasource": { "type": "postgres", "uid": "postgres-srag" },
          "options": { "showHeader": true },
          "targets": [ { "refId": "A", "format": "table", "datasource": { "type": "postgres", "uid": "postgres-srag" }, "rawSql": "SELECT executado_em AS \"Execução\", referencia AS \"Referência\", run_id AS \"Run ID\" FROM auditoria.agente_run ORDER BY executado_em DESC LIMIT 20" } ]
        },
        {
