# Copie para .env e preencha. O .env NUNCA é commitado (ver .gitignore).

# ── Postgres (store analítico) ──
POSTGRES_USER=srag
POSTGRES_PASSWORD=change-me
POSTGRES_DB=srag
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Backend (API + agente) ──
BACKEND_PORT=8000
LOG_LEVEL=INFO

# ── OpenRouter (LLM Claude) ──  https://openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Confirme os slugs exatos em https://openrouter.ai/models
# Haiku 4.5: Claude mais barato — dá conta da narrativa curta e grounded (custo mínimo).
OPENROUTER_MODEL_ORCHESTRATION=anthropic/claude-haiku-4.5
OPENROUTER_MODEL_NARRATIVE=anthropic/claude-haiku-4.5

# ── NewsAPI ──  https://newsapi.org
NEWSAPI_KEY=

# ── LangSmith (tracing opcional dos agentes) ──  https://smith.langchain.com
# Preencha LANGCHAIN_API_KEY para ligar o tracing ao vivo das execuções do agente.
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=srag-report

# ── Grafana ──
GRAFANA_PORT=3000
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# ── SonarQube (profile "quality") ──  token gerado no SonarQube após subir (localhost:9000)
SONAR_TOKEN=
